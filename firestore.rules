rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default catch-all deny rule for absolute security (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles and all related subcollections under user sandbox (Pillars 2, 3, 6, 8)
    match /users/{userId} {
      // Validate that users can only read/edit their own data
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 150;
      allow delete: if false; // Profiles are permanent once created

      // Sub-collections under the user
      match /plans/{planId} {
        allow read, write: if isOwner(userId);
      }

      match /flashcards/{flashcardId} {
        allow read, write: if isOwner(userId);
      }

      match /quizzes/{quizId} {
        allow read, write: if isOwner(userId);
      }

      match /focus/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      match /prayers/{date} {
        allow read, write: if isOwner(userId);
      }

      match /wakeups/{date} {
        allow read, write: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }

      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
